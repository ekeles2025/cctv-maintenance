# انسخ هذا الملف إلى .env أو .env.local وعدّل القيم
# في ويندوز: copy .env.example .env
# في لينكس/ماك: cp .env.example .env

# مفتاح سري للتطبيق (غيّره في الإنتاج!)
SECRET_KEY=ضع-مفتاحا-سريا-قويا-هنا

# قاعدة البيانات
# للتطوير المحلي (SQLite):
DATABASE_URL=sqlite:///camera_system.db

# للإنتاج مع PostgreSQL مثال:
# DATABASE_URL=postgresql://user:password@localhost:5432/camera_system

# اختياري: اسم الشركة
# COMPANY_NAME=CCTV Portal EG

# اختياري: حجم اللوجو بالبكسل (20–200)
# LOGO_SIZE=50

# اختياري: أقصى حجم لملف مرفوع بالبايت (افتراضي 16 ميجا)
# MAX_CONTENT_LENGTH=16777216
