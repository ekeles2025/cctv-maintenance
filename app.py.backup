        db.session.commit()
        flash("تم تسجيل عطل الجهاز بنجاح ✅", "success")
        return redirect(url_for("device_faults", device_id=device_id))

    return render_template("add_edit_device_fault.html", fault=None, device=device, technicians=technicians)

